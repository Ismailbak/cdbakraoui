# Copy to .env on the target machine before running docker compose:
#   copy .env.docker.example .env

# MySQL (used by the db service and backend)
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_PASSWORD=change-me-dentai

# Backend secrets
SECRET_KEY=generate-a-long-random-secret-here
ADMIN_PASSWORD=change-me-admin-password

# Browser origins allowed by the API (use the machine LAN IP)
CORS_ORIGINS=http://192.168.100.78,http://localhost,http://127.0.0.1

# Ollama on the host — model name must match `ollama list` exactly (e.g. gemma4:latest)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:latest

# Web entry port (80 = http://<machine-ip>/)
WEB_PORT=80
