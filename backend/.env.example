# MySQL: create database first: CREATE DATABASE rhumatoai;
# No password (just press Enter in mysql): use root:@...
# With password: use root:YOUR_PASSWORD@...
DATABASE_URL=mysql+pymysql://root:@localhost:3306/rhumatoai

# JWT (change in production)
SECRET_KEY=change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60
