{
  "expo": {
    "name": "Medical AI Mobile",
    "slug": "medical-ai-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/favicon-logo.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/favicon-logo.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-notifications",
      "expo-font"
    ]
  }
}
